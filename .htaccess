# ============================================================
#  RaktSetu — .htaccess
#  Apache configuration · Security · Error pages · URL rules
# ============================================================

# ── PHP version hint (InfinityFree / shared hosts) ──────────
AddType application/x-httpd-php74 .php

# ── Custom error pages ──────────────────────────────────────
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php

# ── Security headers ────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Protect sensitive files ─────────────────────────────────
<FilesMatch "\.(sql|log|env|json|lock|md|gitignore)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Protect config and includes folders ─────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/.*$   /404.php [L]
    RewriteRule ^includes/.*$ /404.php [L]
</IfModule>

# ── Prevent directory listing ───────────────────────────────
Options -Indexes

# ── Prevent direct upload access (non-image files) ──────────
<FilesMatch "uploads/.*\.(php|phtml|php3|php4|php5|phps)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Cache static assets ─────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css            "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/jpeg          "access plus 30 days"
    ExpiresByType image/png           "access plus 30 days"
    ExpiresByType image/svg+xml       "access plus 30 days"
</IfModule>

# ── Gzip compression ────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
